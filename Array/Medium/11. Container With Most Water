class Solution:
    def maxArea(self, height: List[int]) -> int:
        i, j = 0, len(height) - 1
        r = 0
        while i < j:
            a = min(height[i], height[j]) * (j - i)
            if a > r:
                r = a

            if height[i] <= height[j]:
                i += 1
            else:
                j -= 1
        return r
